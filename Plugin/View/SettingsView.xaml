<UserControl
    x:Class="STranslate.Plugin.Vocabulary.Anki.View.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:vm="clr-namespace:STranslate.Plugin.Vocabulary.Anki.ViewModel"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
    d:DesignHeight="500"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ikw:SimpleStackPanel Spacing="12">
        <!-- AnkiConnect URL -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_AnkiConnectUrl}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Globe_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <TextBox
                MinWidth="300"
                ui:ControlHelper.PlaceholderText="http://127.0.0.1:8765"
                Text="{Binding AnkiConnectUrl, UpdateSourceTrigger=PropertyChanged}" />
        </ui:SettingsCard>

        <!-- 测试连接按钮 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_TestConnection}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon
                    Foreground="{DynamicResource {x:Static ui:ThemeKeys.SystemFillColorSuccessBrushKey}}"
                    Icon="{x:Static ui:FluentSystemIcons.CheckmarkCircle_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ui:SettingsCard.Description>
                <TextBlock>
                    <TextBlock.Style>
                        <Style BasedOn="{StaticResource {x:Type TextBlock}}" TargetType="TextBlock">
                            <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Vocabulary_Anki_ConnectionFail}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource STranslate_Plugin_Vocabulary_Anki_ConnectionOK}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </ui:SettingsCard.Description>
            <Button
                Command="{Binding TestConnectionCommand}"
                Style="{StaticResource AccentButtonStyle}">
                <ui:IconAndText
                    Content="{DynamicResource STranslate_Plugin_Vocabulary_Anki_TestConnection}"
                    Icon="{x:Static ui:FluentSystemIcons.Play_20_Regular}" />
            </Button>
        </ui:SettingsCard>

        <!-- 牌组选择 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_DeckName}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Notebook_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <ComboBox
                    MinWidth="250"
                    IsEditable="True"
                    ItemsSource="{Binding Decks}"
                    Text="{Binding DeckName}" />
                <Button
                    Margin="8,0,0,0"
                    Command="{Binding RefreshDecksCommand}"
                    Style="{StaticResource AccentButtonStyle}">
                    <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.ArrowSync_20_Regular}" />
                </Button>
            </StackPanel>
        </ui:SettingsCard>

        <!-- 笔记类型选择 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_ModelName}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Document_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <StackPanel Orientation="Horizontal">
                <ComboBox
                    MinWidth="250"
                    IsEditable="True"
                    ItemsSource="{Binding Models}"
                    Text="{Binding ModelName}" />
                <Button
                    Margin="8,0,0,0"
                    Command="{Binding RefreshModelsCommand}"
                    Style="{StaticResource AccentButtonStyle}">
                    <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.ArrowSync_20_Regular}" />
                </Button>
            </StackPanel>
        </ui:SettingsCard>

        <!-- 源文本字段 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_FieldSource}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TextField_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox
                MinWidth="250"
                IsEditable="True"
                ItemsSource="{Binding SourceFields}"
                Text="{Binding FieldMappingSource}" />
        </ui:SettingsCard>

        <!-- 翻译字段 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_FieldTarget}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.TextField_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox
                MinWidth="250"
                IsEditable="True"
                ItemsSource="{Binding TargetFields}"
                Text="{Binding FieldMappingTarget}" />
        </ui:SettingsCard>

        <!-- 标签 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_Tags}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Tag_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <TextBox
                MinWidth="300"
                ui:ControlHelper.PlaceholderText="stranslate"
                Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}" />
        </ui:SettingsCard>

        <!-- 允许重复 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_AllowDuplicate}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Copy_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <CheckBox IsChecked="{Binding AllowDuplicate}" />
        </ui:SettingsCard>

        <!-- 去重检查字段 -->
        <ui:SettingsCard Header="{DynamicResource STranslate_Plugin_Vocabulary_Anki_DuplicateCheckField}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:FluentSystemIcons.Search_20_Regular}" />
            </ui:SettingsCard.HeaderIcon>
            <ComboBox
                MinWidth="250"
                IsEditable="True"
                ItemsSource="{Binding SourceFields}"
                Text="{Binding DuplicateCheckField}" />
        </ui:SettingsCard>

    </ikw:SimpleStackPanel>
</UserControl>
