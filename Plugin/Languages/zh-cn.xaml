<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DictionaryPath">词典数据库路径</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DictionaryPath_Description">ECDICT SQLite 数据库文件路径，留空或相对路径则使用插件目录下的默认文件</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_LemmaPath">词形还原数据路径</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_LemmaPath_Description">lemma.en.txt 文件路径，用于词形还原（如 gave -> give）</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableLemma">启用词形还原</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableLemma_Description">查询单词变体时自动还原为原型词</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableFuzzyMatch">启用模糊匹配</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableFuzzyMatch_Description">精确匹配失败时，尝试 stripword 模糊匹配</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_MaxFuzzyResults">最大模糊匹配数</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_MaxFuzzyResults_Description">模糊匹配时返回的最大结果数量</sys:String>

    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DisplayOptions">显示选项</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DisplayOptions_Description">选择要在查询结果中显示的内容</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPlurals">显示复数形式</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPastTense">显示过去式</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPastParticiple">显示过去分词</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPresentParticiple">显示现在分词 / 动名词</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowThirdPersonSingular">显示第三人称单数</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowTags">显示标签（考试等级等）</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowSourceInfo">显示来源信息（柯林斯星级、词频等）</sys:String>


</ResourceDictionary>
