<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DictionaryPath">Dictionary Database Path</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DictionaryPath_Description">Path to ECDICT SQLite database file; uses plugin directory default if relative or empty</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_LemmaPath">Lemma Data Path</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_LemmaPath_Description">Path to lemma.en.txt for word form lemmatization (e.g. gave -> give)</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableLemma">Enable Lemmatization</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableLemma_Description">Automatically reduce word variants to their base form</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableFuzzyMatch">Enable Fuzzy Match</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_EnableFuzzyMatch_Description">Try stripword fuzzy matching when exact match fails</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_MaxFuzzyResults">Max Fuzzy Results</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_MaxFuzzyResults_Description">Maximum number of results to return during fuzzy matching</sys:String>

    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DisplayOptions">Display Options</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_DisplayOptions_Description">Choose what to show in query results</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPlurals">Show Plural Forms</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPastTense">Show Past Tense</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPastParticiple">Show Past Participle</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowPresentParticiple">Show Present Participle / Gerund</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowThirdPersonSingular">Show Third-Person Singular</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowTags">Show Tags (Exam Levels etc.)</sys:String>
    <sys:String x:Key="STranslate_Plugin_Dictionary_ECDICT_ShowSourceInfo">Show Source Info (Collins Stars, Frequency etc.)</sys:String>


</ResourceDictionary>
